{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,

  "python.analysis.extraPaths": ["${workspaceFolder}"],
  "python.analysis.venvPath": "${workspaceFolder}",
  "python.analysis.venv": ".venv",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.ignore": [".venv/**", "alembic/**"],

  "pyre.binaryPath": "${workspaceFolder}/.venv/bin/pyre",
  "pyre.searchPath": ["${workspaceFolder}/.venv/lib/python3.14/site-packages"],
  "pyre.pythonPath": "${workspaceFolder}/.venv/bin/python",

  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  }
}
